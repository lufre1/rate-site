# PostgreSQL
DB_USER=user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=mensa_db

# Backend connection (must match DB_USER, POSTGRES_PASSWORD, POSTGRES_DB)
DATABASE_URL=postgresql://user:change-me-strong-password@db:5432/mensa_db

# Frontend API URL used at build time
# If using nginx reverse proxy (path-based): set to "/api"
# If using separate hosts: set to "https://mensa-api.example.com"
REACT_APP_API_URL=http://localhost:8000
